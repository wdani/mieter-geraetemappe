# In Netlify als geheime Umgebungsvariable anlegen.
ADMIN_PASSWORD=hier-ein-langes-sicheres-passwort-eintragen

# Optional: Dropbox als zweiten Backup-Speicher verwenden.
# Der Refresh Token wird nach dem Klick auf „Dropbox verbinden“ intern gespeichert.
DROPBOX_APP_KEY=dropbox-app-key
DROPBOX_APP_SECRET=dropbox-app-secret
DROPBOX_BACKUP_PATH=/Geraetemappe-Backups
